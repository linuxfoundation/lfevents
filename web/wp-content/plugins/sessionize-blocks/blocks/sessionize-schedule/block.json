{
  "$schema": "https://schemas.wp.org/trunk/block.json",
  "apiVersion": 3,
  "name": "custom/sessionize-schedule",
  "version": "0.1.0",
  "title": "Sessionize Schedule",
  "category": "widgets",
  "icon": "calendar-alt",
  "description": "An interactive, dynamic schedule block powered by Sessionize. Fields marked * are required.",
  "textdomain": "sessionize-blocks",
  "attributes": {
    "apiCode": {
      "type": "string",
      "default": ""
    },
    "publicSlug": {
      "type": "string",
      "default": ""
    },
    "primaryFilterTitle": {
      "type": "string",
      "default": ""
    },
    "timeFormat": {
      "type": "string",
      "default": "12h"
    },
    "dateFormat": {
      "type": "string",
      "default": "mdy"
    },
    "enableGridView": {
      "type": "boolean",
      "default": true
    },
    "enablePersonalAgenda": {
      "type": "boolean",
      "default": false
    },
    "defaultShowAllDays": {
      "type": "boolean",
      "default": true
    },
    "hideTopControls": {
      "type": "boolean",
      "default": false
    },
    "speakerTitleQuestionId": {
      "type": "string",
      "default": "Speaker Title"
    },
    "speakerCompanyQuestionId": {
      "type": "string",
      "default": "Company"
    },
    "speakerCompanyOverrideQuestionId": {
      "type": "string",
      "default": ""
    },
    "cardSpeakerOverrideQuestionId": {
      "type": "string",
      "default": ""
    },
    "presentationSlidesQuestionId": {
      "type": "string",
      "default": "Presentation Slides"
    },
    "customLinkField1QuestionId": {
      "type": "string",
      "default": ""
    },
    "customLinkField2QuestionId": {
      "type": "string",
      "default": ""
    },
    "customLinkField3QuestionId": {
      "type": "string",
      "default": ""
    },
    "customLinkField4QuestionId": {
      "type": "string",
      "default": ""
    },
    "customLinkField5QuestionId": {
      "type": "string",
      "default": ""
    },
    "hiddenFilterCategories": {
      "type": "string",
      "default": ""
    },
    "hideSessionChipsForCategories": {
      "type": "string",
      "default": ""
    },
    "hideAllChipsForPrimaryValues": {
      "type": "string",
      "default": ""
    },
    "includeSpeakerTitleForPrimaryValues": {
      "type": "string",
      "default": ""
    },
    "companyRollupNames": {
      "type": "string",
      "default": ""
    },
    "primaryColorOverrides": {
      "type": "string",
      "default": "{}"
    }
  },
  "editorScript": "file:./build/index.js",
  "viewScript": "file:./build/view.js",
  "style": "file:./build/style-index.css",
  "render": "file:./render.php"
}